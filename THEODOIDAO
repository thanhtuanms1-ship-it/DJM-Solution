<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Quản Lý Dao Cụ Pro</title>
    <script src="https://jsdelivr.net"></script>
    <style>
        :root {
            --primary-color: #1e3a8a; --secondary-color: #0d9488; --danger-color: #ef4444;
            --accent-color: #f59e0b; --backup-color: #7c3aed; --background-color: #f8fafc;
            --text-color: #1e293b; --card-background: #ffffff;
        }
        * { box-sizing: border-box; margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, Arial, sans-serif; }
        body { background-color: var(--background-color); color: var(--text-color); padding: 12px; display: flex; flex-direction: column; align-items: center; min-height: 100vh; }
        .container { width: 100%; max-width: 600px; background: var(--card-background); padding: 16px; border-radius: 12px; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1); }
        h1, h2 { text-align: center; margin-bottom: 20px; color: var(--primary-color); font-size: 1.4rem; }
        .menu-grid { display: flex; flex-direction: column; gap: 14px; }
        .btn { width: 100%; padding: 14px; font-size: 1rem; font-weight: bold; border: none; border-radius: 8px; cursor: pointer; text-align: center; -webkit-tap-highlight-color: transparent; }
        .btn-primary { background-color: var(--primary-color); color: white; }
        .btn-secondary { background-color: var(--secondary-color); color: white; }
        .btn-danger { background-color: var(--danger-color); color: white; padding: 6px 10px; font-size: 0.8rem; border-radius: 4px; width: auto; }
        .btn-back { background-color: #64748b; color: white; margin-bottom: 16px; padding: 10px; font-size: 0.9rem; }
        .backup-section { margin-top: 20px; padding: 15px; border: 1px dashed var(--backup-color); background-color: #f5f3ff; border-radius: 8px; }
        .btn-backup { background-color: var(--backup-color); color: white; margin-bottom: 10px; }
        .btn-restore { background-color: #4b5563; color: white; }
        .form-group { margin-bottom: 14px; }
        .form-group label { display: block; margin-bottom: 4px; font-weight: 600; font-size: 0.9rem; }
        .form-control { width: 100%; padding: 10px; border: 1px solid #cbd5e1; border-radius: 6px; font-size: 1rem; background-color: #fff; }
        .form-control:focus { outline: none; border-color: var(--secondary-color); }
        .file-input-wrapper { margin-bottom: 15px; padding: 10px; border: 2px dashed #cbd5e1; border-radius: 6px; text-align: center; background: #f1f5f9; }
        .result-box { background: #f0fdf4; border-left: 4px solid var(--secondary-color); padding: 12px; margin: 15px 0; border-radius: 4px; }
        .section-title { margin-top: 15px; font-size: 0.95rem; color: var(--accent-color); font-weight: bold; border-bottom: 1px solid #e2e8f0; padding-bottom: 4px; }
        .table-container { margin-top: 15px; overflow-x: auto; width: 100%; border-radius: 6px; border: 1px solid #e2e8f0; }
        table { width: 100%; border-collapse: collapse; font-size: 0.85rem; text-align: left; }
        th, td { padding: 8px 10px; border-bottom: 1px solid #e2e8f0; }
        th { background-color: #f1f5f9; color: var(--primary-color); font-weight: 600; white-space: nowrap; }
        .page { display: none; width: 100%; }
        .page.active { display: block; }
        .hint-text { font-size: 0.8rem; color: #64748b; margin-top: 4px; }
    </style>
</head>
<body>
    <div class="container">
        <!-- MÀN HÌNH CHÍNH -->
        <div id="page-home" class="page active">
            <h1>QUẢN LÝ DAO CỤ</h1>
            <div class="menu-grid">
                <button class="btn btn-primary" onclick="switchPage('page-param')">TRA THÔNG SỐ DAO</button>
                <button class="btn btn-secondary" onclick="switchPage('page-history')">LÝ LỊCH CHẾ DAO</button>
                <div class="backup-section">
                    <p style="font-weight: bold; color: var(--backup-color); margin-bottom: 10px; text-align: center; font-size: 0.9rem;">HỆ THỐNG DỮ LIỆU AN TOÀN</p>
                    <button class="btn btn-backup" onclick="exportBackupData()">📥 XUẤT FILE SAO LƯU (.JSON)</button>
                    <label class="btn btn-restore" style="display: block; text-align: center; cursor: pointer; padding: 14px; border-radius: 8px; font-weight: bold;">
                        📤 KHÔI PHỤC DỮ LIỆU TỪ FILE
                        <input type="file" id="restore-file" accept=".json" onchange="importBackupData(this)" style="display: none;">
                    </label>
                    <div class="hint-text" style="text-align: center; margin-top: 6px;">Lưu file sang USB hoặc Zalo để dự phòng khi đổi máy.</div>
                </div>
            </div>
        </div>

        <!-- TRANG TRA THÔNG SỐ -->
        <div id="page-param" class="page">
            <button class="btn btn-back" onclick="switchPage('page-home')">← Quay lại</button>
            <h2>TRA THÔNG SỐ DAO</h2>
            <div class="file-input-wrapper">
                <label style="font-weight: bold; display:block; margin-bottom:5px;">Nạp bộ nhớ từ file Excel</label>
                <input type="file" id="excel-file" accept=".xlsx, .xls" onchange="importExcel(this)" class="form-control" style="padding:5px; font-size:0.85rem;">
                <div class="hint-text">File gồm cột: "Tên dao" và "Thông số CCW"</div>
                <div id="excel-status" style="margin-top:5px; font-weight:bold; color:var(--secondary-color); font-size:0.85rem;"></div>
            </div>
            <div class="form-group">
                <label for="search-input">Nhập tên dao cần tra cứu:</label>
                <input type="text" id="search-input" class="form-control" placeholder="Ví dụ: Dao cắt 01..." oninput="searchKnife()">
            </div>
            <div id="search-result" style="display: none;">
                <div class="result-box">
                    <p><strong>Tên dao:</strong> <span id="res-name"></span></p>
                    <p style="margin-top: 5px;"><strong>Thông số CCW:</strong> <span id="res-ccw" style="font-size:1.1rem; color:var(--primary-color); font-weight:bold;"></span></p>
                </div>
                <div class="section-title">DAO CÓ CCW TƯƠNG ĐỒNG (SAI LỆCH ≤ 0.05)</div>
                <div class="table-container">
                    <table id="suggest-table">
                        <thead><tr><th>Tên dao</th><th>Thông số CCW</th><th>Độ lệch</th></tr></thead>
                        <tbody></tbody>
                    </table>
                </div>
            </div>
            <div id="search-empty" style="text-align: center; color: #64748b; margin-top: 15px;">Chưa tìm thấy hoặc chưa nạp dữ liệu.</div>
        </div>

        <!-- TRANG LÝ LỊCH CHẾ DAO -->
        <div id="page-history" class="page">
            <button class="btn btn-back" onclick="switchPage('page-home')">← Quay lại</button>
            <h2>LÝ LỊCH CHẾ DAO</h2>
            <form id="history-form" onsubmit="saveHistoryData(event)">
                <div class="form-group"><label>Dao gốc</label><input type="text" id="input-original" class="form-control" required></div>
                <div class="form-group"><label>Dao thay thế</label><input type="text" id="input-replace" class="form-control" required></div>
                <div class="form-group"><label>Ngày duyệt</label><input type="date" id="input-date" class="form-control" required></div>
                <div class="form-group">
                    <label>Loại Tool</label>
                    <select id="input-type" class="form-control" required>
                        <option value="" disabled selected>Chọn loại tool</option>
                        <option value="A">A</option><option value="B">B</option><option value="C">C</option><option value="D">D</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-secondary">LƯU LÝ LỊCH</button>
            </form>
            <div class="table-container">
                <table id="history-table">
                    <thead><tr><th>Ngày</th><th>Dao gốc</th><th>Dao thay</th><th>Loại</th><th>Xóa</th></tr></thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>
    <script>
        // Khởi tạo và đồng bộ LocalStorage
        let dbKnives = JSON.parse(localStorage.getItem('dbKnives')) || [];
        let historyList = JSON.parse(localStorage.getItem('historyList')) || [];

        window.onload = function() {
            document.getElementById('input-date').valueAsDate = new Date();
            updateExcelStatusText();
            renderHistoryTable();
        };

        function updateExcelStatusText() {
            const statusDiv = document.getElementById('excel-status');
            if (statusDiv) {
                statusDiv.innerText = dbKnives.length > 0 ? `Đã nạp sẵn ${dbKnives.length} dao từ bộ nhớ máy.` : `Chưa có dữ liệu dao trong bộ nhớ.`;
            }
        }

        function switchPage(pageId) {
            document.querySelectorAll('.page').forEach(page => page.classList.remove('active'));
            document.getElementById(pageId).classList.add('active');
            if(pageId === 'page-home') updateExcelStatusText();
        }

        // Xuất toàn bộ dữ liệu máy ra file JSON
        function exportBackupData() {
            if (dbKnives.length === 0 && historyList.length === 0) {
                alert("Bộ nhớ trống, không có dữ liệu để sao lưu!"); return;
            }
            const backupPackage = { version: "2026-PRO", dbKnives: dbKnives, historyList: historyList };
            const dataStr = "data:text/json;charset=utf-8," + encodeURIComponent(JSON.stringify(backupPackage));
            const downloadAnchor = document.createElement('a');
            const now = new Date();
            const dateLabel = `${now.getFullYear()}${String(now.getMonth()+1).padStart(2,'0')}${String(now.getDate()).padStart(2,'0')}`;
            downloadAnchor.setAttribute("href", dataStr);
            downloadAnchor.setAttribute("download", `saoluu_mamay_dao_${dateLabel}.json`);
            document.body.appendChild(downloadAnchor);
            downloadAnchor.click(); downloadAnchor.remove();
        }

        // Khôi phục dữ liệu tổng ghi đè vào LocalStorage
        function importBackupData(inputElement) {
            const file = inputElement.files[0]; if (!file) return;
            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const parsedData = JSON.parse(e.target.result);
                    if (parsedData.dbKnives || parsedData.historyList) {
                        if (confirm("Hành động này sẽ GHI ĐÈ toàn bộ dữ liệu hiện tại trên điện thoại. Xác nhận khôi phục?")) {
                            dbKnives = parsedData.dbKnives || [];
                            historyList = parsedData.historyList || [];
                            localStorage.setItem('dbKnives', JSON.stringify(dbKnives));
                            localStorage.setItem('historyList', JSON.stringify(historyList));
                            updateExcelStatusText(); renderHistoryTable();
                            alert(`Khôi phục thành công! Tải lại ${dbKnives.length} dao và ${historyList.length} dòng lý lịch.`);
                        }
                    } else { alert("File không đúng cấu trúc."); }
                } catch (err) { alert("Lỗi khi đọc file sao lưu."); }
                inputElement.value = '';
            };
            reader.readAsText(file);
        }
        // Xử lý nạp danh sách dao từ file Excel
        function importExcel(element) {
            const file = element.files[0]; if (!file) return;
            const reader = new FileReader();
            reader.onload = function(e) {
                try {
                    const data = new Uint8Array(e.target.result);
                    const workbook = XLSX.read(data, { type: 'array' });
                    const worksheet = workbook.Sheets[workbook.SheetNames[0]];
                    const jsonData = XLSX.utils.sheet_to_json(worksheet);

                    dbKnives = jsonData.map(row => {
                        const nameKey = Object.keys(row).find(k => k.toLowerCase().replace(/\s/g, '') === 'têndao');
                        const ccwKey = Object.keys(row).find(k => k.toLowerCase().replace(/\s/g, '') === 'thôngsốccw' || k.toLowerCase() === 'ccw');
                        return {
                            name: row[nameKey] ? String(row[nameKey]).trim() : '',
                            ccw: row[ccwKey] ? parseFloat(row[ccwKey]) : 0
                        };
                    }).filter(item => item.name !== '');

                    localStorage.setItem('dbKnives', JSON.stringify(dbKnives));
                    updateExcelStatusText();
                    alert(`Nạp thành công ${dbKnives.length} loại dao từ Excel vào máy!`);
                    searchKnife();
                } catch (err) { alert('Lỗi file. Cần 2 cột: "Tên dao" và "Thông số CCW"'); }
                element.value = '';
            };
            reader.readAsArrayBuffer(file);
        }

        // Bộ lọc tra cứu tìm kiếm sai lệch 0.05
        function searchKnife() {
            const keyword = document.getElementById('search-input').value.trim().toLowerCase();
            const resBox = document.getElementById('search-result');
            const emptyBox = document.getElementById('search-empty');
            const suggestTbody = document.querySelector('#suggest-table tbody');

            if (!keyword) { resBox.style.display = 'none'; emptyBox.style.display = 'block'; return; }
            const targetKnife = dbKnives.find(k => k.name.toLowerCase() === keyword || k.name.toLowerCase().includes(keyword));

            if (!targetKnife) { resBox.style.display = 'none'; emptyBox.style.display = 'block'; emptyBox.innerText = 'Không tìm thấy dao.'; return; }
            emptyBox.style.display = 'none'; resBox.style.display = 'block';
            document.getElementById('res-name').innerText = targetKnife.name;
            document.getElementById('res-ccw').innerText = targetKnife.ccw;

            suggestTbody.innerHTML = '';
            const targetCCW = targetKnife.ccw;

            dbKnives.forEach(knife => {
                const diff = Math.abs(knife.ccw - targetCCW);
                if (diff <= 0.05 && knife.name !== targetKnife.name) {
                    const row = document.createElement('tr');
                    const diffSign = knife.ccw > targetCCW ? `+${diff.toFixed(3)}` : (knife.ccw < targetCCW ? `-${diff.toFixed(3)}` : 'Bằng');
                    row.innerHTML = `<td><strong>${knife.name}</strong></td><td>${knife.ccw}</td><td style="color: ${diff === 0 ? 'green' : '#b45309'}">${diffSign}</td>`;
                    suggestTbody.appendChild(row);
                }
            });
            if(suggestTbody.innerHTML === '') suggestTbody.innerHTML = `<tr><td colspan="3" style="text-align:center; color:#64748b;">Không có dao lệch trong khoảng ±0.05</td></tr>`;
        }

        // Xử lý quản lý và render bảng lý lịch
        function formatDate(dateString) {
            if(!dateString) return '';
            const date = new Date(dateString);
            return `${String(date.getDate()).padStart(2, '0')}/${String(date.getMonth() + 1).padStart(2, '0')}/${date.getFullYear()}`;
        }

        function saveHistoryData(event) {
            event.preventDefault();
            const newData = {
                id: Date.now(),
                original: document.getElementById('input-original').value.trim(),
                replace: document.getElementById('input-replace').value.trim(),
                date: document.getElementById('input-date').value,
                type: document.getElementById('input-type').value
            };
            historyList.push(newData);
            localStorage.setItem('historyList', JSON.stringify(historyList));
            renderHistoryTable(); document.getElementById('history-form').reset();
            document.getElementById('input-date').valueAsDate = new Date();
        }

        function renderHistoryTable() {
            const tbody = document.querySelector('#history-table tbody');
            if(!tbody) return; tbody.innerHTML = '';
            historyList.forEach(item => {
                const row = document.createElement('tr');
                row.innerHTML = `<td>${formatDate(item.date)}</td><td>${item.original}</td><td>${item.replace}</td><td><span style="font-weight:bold; color:var(--primary-color)">${item.type}</span></td><td><button class="btn btn-danger" onclick="deleteHistoryItem(${item.id})">Xóa</button></td>`;
                tbody.appendChild(row);
            });
        }

        function deleteHistoryItem(id) {
            if (confirm("Bạn có chắc chắn muốn xóa dòng lý lịch đang chọn không?")) {
                historyList = historyList.filter(item => item.id !== id);
                localStorage.setItem('historyList', JSON.stringify(historyList));
                renderHistoryTable();
            }
        }
    </script>
</body>
</html>
